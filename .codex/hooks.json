{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "^apply_patch$|^Edit$|^Write$",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/clang_format_after_edit.py\"",
            "commandWindows": "python \"$(git rev-parse --show-toplevel)\\.codex\\hooks\\clang_format_after_edit.py\"",
            "timeout": 30,
            "statusMessage": "Formatting edited C/C++ files"
          }
        ]
      }
    ]
  }
}
