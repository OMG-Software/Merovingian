{
  "name": "v1.18 client-server beta endpoint coverage",
  "description": "Complement-style fixture that exercises authentication, devices, rooms, sync, media, reports, and E2EE key APIs through the Matrix client-server adapter, including rejected unauthenticated, malformed, stale-token, cross-user, and missing-resource cases.",
  "steps": [
    {
      "method": "GET",
      "path": "/_matrix/client/versions",
      "expect_status": 200,
      "expect_keys_present": ["versions", "unstable_features"]
    },
    {
      "method": "GET",
      "path": "/_matrix/client/v3/login",
      "expect_status": 200,
      "expect_keys_present": ["flows"]
    },
    {
      "method": "GET",
      "path": "/_matrix/client/v3/account/whoami",
      "expect_status": 401,
      "expect_keys_present": ["errcode", "error"]
    },
    {
      "method": "POST",
      "path": "/_matrix/client/v3/register",
      "body": {
        "username": "blocked",
        "password": "CorrectHorse7!"
      },
      "expect_status": 401,
      "expect_keys_present": ["flows", "session"]
    },
    {
      "method": "POST",
      "path": "/_matrix/client/v3/register",
      "body": {
        "username": "alice",
        "password": "CorrectHorse7!",
        "auth": {
          "type": "m.login.registration_token",
          "token": "test-registration-token"
        }
      },
      "expect_status": 200,
      "expect_keys_present": ["user_id"]
    },
    {
      "method": "POST",
      "path": "/_matrix/client/v3/login",
      "body": {
        "type": "m.login.password",
        "identifier": {"type": "m.id.user", "user": "@alice:example.org"},
        "password": "wrong-password",
        "device_id": "BADDEVICE"
      },
      "expect_status": 403,
      "expect_keys_present": ["errcode", "error"]
    },
    {
      "method": "POST",
      "path": "/_matrix/client/v3/login",
      "body": {
        "type": "m.login.password",
        "identifier": {"type": "m.id.user", "user": "@alice:example.org"},
        "password": "CorrectHorse7!",
        "device_id": "DEVICE1",
        "refresh_token": true
      },
      "expect_status": 200,
      "expect_keys_present": ["access_token", "refresh_token", "user_id", "device_id", "expires_in_ms"],
      "save_string": {
        "alice_token": "access_token",
        "alice_refresh": "refresh_token"
      }
    },
    {
      "method": "POST",
      "path": "/_matrix/client/v3/refresh",
      "body": {"refresh_token": "{{alice_refresh}}"},
      "expect_status": 200,
      "expect_keys_present": ["access_token", "refresh_token", "expires_in_ms"],
      "save_string": {"refreshed_token": "access_token"}
    },
    {
      "method": "GET",
      "path": "/_matrix/client/v3/account/whoami",
      "auth_from": "alice_token",
      "expect_status": 401,
      "expect_keys_present": ["errcode", "error"]
    },
    {
      "method": "POST",
      "path": "/_matrix/client/v3/refresh",
      "body": {"refresh_token": "{{alice_refresh}}"},
      "expect_status": 401,
      "expect_keys_present": ["errcode", "error"]
    },
    {
      "method": "POST",
      "path": "/_matrix/client/v3/refresh",
      "body": {},
      "expect_status": 400,
      "expect_keys_present": ["errcode", "error"]
    },
    {
      "method": "POST",
      "path": "/_matrix/client/v3/login",
      "body": {
        "type": "m.login.password",
        "identifier": {"type": "m.id.user", "user": "@alice:example.org"},
        "password": "CorrectHorse7!",
        "device_id": "DEVICE-NO-REFRESH"
      },
      "expect_status": 200,
      "expect_keys_present": ["access_token", "user_id", "device_id"],
      "expect_keys_absent": ["refresh_token", "expires_in_ms"]
    },
    {
      "method": "GET",
      "path": "/_matrix/client/v3/account/whoami",
