Checks: >
  clang-analyzer-*,
  bugprone-*,
  cert-*,
  cppcoreguidelines-*,
  modernize-*,
  performance-*,
  portability-*,
  readability-*
WarningsAsErrors: '*'
HeaderFilterRegex: 'include/merovingian/.*'
CheckOptions:
  - key: cppcoreguidelines-owning-memory
    value: '1'
  - key: readability-identifier-naming.MemberVariablePrefix
    value: 'm_'
  - key: readability-identifier-naming.MemberVariableCase
    value: 'lower_case'
