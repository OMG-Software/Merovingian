#!/bin/sh
# $OpenBSD: +INSTALL,v 1.0 2026/05/19 00:00:00 merovingian Exp $
# pkg_add(1) calls this script with two arguments: the package name and
# the installation phase (PRE-INSTALL or POST-INSTALL).
PKG_NAME="$1"
PHASE="$2"

case "${PHASE}" in
PRE-INSTALL)
    # Create group and system user before files are laid down.
    if ! grep -q '^merovingian:' /etc/group; then
        groupadd merovingian
    fi
    if ! grep -q '^merovingian:' /etc/passwd; then
        useradd \
            -g merovingian \
            -d /var/db/merovingian \
            -s /sbin/nologin \
            -c "Merovingian homeserver" \
            merovingian
    fi
    ;;
POST-INSTALL)
    # Create runtime directories owned by the service user.
    install -d -o merovingian -g merovingian -m 0750 /var/db/merovingian
    install -d -o merovingian -g merovingian -m 0750 /var/log/merovingian

    # Generate a registration token on first install.
    TOKEN_FILE=/etc/merovingian/registration-token
    if [ ! -f "${TOKEN_FILE}" ]; then
        mkdir -p /etc/merovingian
        openssl rand -base64 48 > "${TOKEN_FILE}"
        chmod 0640 "${TOKEN_FILE}"
        chown root:merovingian "${TOKEN_FILE}"
    fi

    echo ""
    echo "Merovingian installed. Edit /etc/merovingian/merovingian.conf.sample,"
    echo "then enable and start the service:"
    echo "  rcctl enable merovingian"
    echo "  rcctl start merovingian"
    ;;
esac
